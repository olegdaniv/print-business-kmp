# Database Configuration
POSTGRES_USER=printbusiness
POSTGRES_PASSWORD=change_this_password
POSTGRES_DB=printbusiness_db

# Application Configuration (optional)
APP_PORT=8080

# Google Sign-In + App JWT
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
ALLOWED_EMAILS=admin@example.com,owner@example.com
JWT_SECRET=replace-with-a-long-random-secret
JWT_ISSUER=print-business-api
JWT_AUDIENCE=print-business-client

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:8081,https://app.example.com
