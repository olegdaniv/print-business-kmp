# Runtime images (publish these from CI to GHCR or DockerHub)
BACKEND_IMAGE=ghcr.io/CHANGE_ME/print-business-backend:latest
WEB_IMAGE=ghcr.io/CHANGE_ME/print-business-web:latest

# Local database credentials (override on each machine as needed)
POSTGRES_DB=printbusiness_db
POSTGRES_USER=printbusiness
POSTGRES_PASSWORD=change-me-local-only

# Web port on host
WEB_PORT=80

# Auto-update behavior
WATCHTOWER_ENABLED=true
WATCHTOWER_SCOPE=print-business-kmp
WATCHTOWER_POLL_SECONDS=300
