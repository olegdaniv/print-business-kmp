{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Run desktopApp",
            "type": "shell",
            "command": "./gradlew",
            "args": [
                ":desktopApp:run"
            ],
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "new"
            }
        },
        {
            "label": "Run Web Admin",
            "type": "shell",
            "command": "./gradlew",
            "args": [
                ":webApp:jsBrowserDevelopmentRun",
                "--continuous",
                "--stacktrace"
            ],
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "new"
            }
        }
    ]
}